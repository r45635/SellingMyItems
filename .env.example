# Example environment configuration. Copy to `.env` and fill in.
# Only DATABASE_URL is strictly required to boot (see src/instrumentation.ts).

# ── Database (required) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/sellingmyitems

# ── App ──────────────────────────────────────────────────────────────────────
# Base URL used in outgoing email links. Defaults to http://localhost:3000.
# NEXT_PUBLIC_APP_URL=https://sellingmyitems.example.com

# ── Redis (optional) ─────────────────────────────────────────────────────────
# Enables Redis-backed rate limiting. Falls back to in-memory when unset.
# REDIS_URL=redis://localhost:6379

# ── Email (optional) ─────────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=SellingMyItems <onboarding@resend.dev>

# ── Storage ──────────────────────────────────────────────────────────────────
# Where uploaded item images are stored.
#   unset / "local"  → local filesystem under public/uploads (DEFAULT).
#   "s3"             → S3-compatible object store (AWS S3, Cloudflare R2, MinIO).
# The default is local — leave STORAGE_PROVIDER unset (or =local) and none of
# the STORAGE_* vars below are needed.
# STORAGE_PROVIDER=local
#
# The following are REQUIRED only when STORAGE_PROVIDER=s3:
# STORAGE_BUCKET=my-bucket
# STORAGE_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
# STORAGE_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Public base URL images are served from (CDN / public bucket URL). Used both to
# build stored image URLs and to whitelist the host for next/image.
# STORAGE_PUBLIC_BASE_URL=https://images.example.com
